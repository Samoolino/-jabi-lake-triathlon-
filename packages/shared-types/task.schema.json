{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "priority": { "type": "number" },
    "assignedAgent": { "type": "string" },
    "state": { "type": "string", "enum": ["created","assigned","active","completed"] }
  },
  "required": ["id","title"]
}
